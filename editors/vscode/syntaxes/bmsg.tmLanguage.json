{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "ByteMsg",
  "scopeName": "source.bmsg",
  "patterns": [
    {
      "include": "#comment"
    },
    {
      "include": "#header"
    },
    {
      "include": "#annotation"
    },
    {
      "include": "#block-declaration"
    },
    {
      "include": "#field"
    },
    {
      "include": "#enum-value"
    },
    {
      "include": "#builtin-types"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#punctuation"
    }
  ],
  "repository": {
    "comment": {
      "name": "comment.line.double-slash.bmsg",
      "begin": "//",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.comment.bmsg"
        }
      },
      "end": "$",
      "patterns": [
        {
          "name": "string.quoted.double.bmsg",
          "match": "\"[^\"\\\\]*(?:\\\\.[^\"\\\\]*)*\""
        },
        {
          "name": "keyword.operator.pipe.bmsg",
          "match": "\\|"
        }
      ]
    },
    "header": {
      "patterns": [
        {
          "name": "meta.header.schema.bmsg",
          "match": "^(\\s*)(schema)(\\s*:\\s*)([^\\s].*)$",
          "captures": {
            "2": {
              "name": "keyword.control.header.bmsg"
            },
            "3": {
              "name": "punctuation.separator.key-value.bmsg"
            },
            "4": {
              "name": "constant.other.schema-version.bmsg"
            }
          }
        },
        {
          "name": "meta.header.package.bmsg",
          "match": "^(\\s*)(package)(\\s*:\\s*)([A-Za-z_][A-Za-z0-9_\\.]*)$",
          "captures": {
            "2": {
              "name": "keyword.control.header.bmsg"
            },
            "3": {
              "name": "punctuation.separator.key-value.bmsg"
            },
            "4": {
              "name": "entity.name.namespace.bmsg"
            }
          }
        }
      ]
    },
    "annotation": {
      "patterns": [
        {
          "name": "meta.annotation.type.bmsg",
          "match": "^(\\s*)(@type|@alias)(\\s+)([A-Za-z_][A-Za-z0-9_]*(?:\\[[A-Za-z_][A-Za-z0-9_]*\\])?)(\\s*)(=)(\\s*)([^\\s].*?)(?=\\s*(?://.*)?$)",
          "captures": {
            "2": {
              "name": "storage.type.annotation.bmsg"
            },
            "4": {
              "name": "entity.name.type.alias-source.bmsg"
            },
            "6": {
              "name": "keyword.operator.assignment.bmsg"
            },
            "8": {
              "name": "entity.name.type.alias-target.bmsg"
            }
          }
        }
      ]
    },
    "block-declaration": {
      "patterns": [
        {
          "name": "meta.declaration.enum.bmsg",
          "match": "^(\\s*)(enum)(\\s+)([A-Za-z_][A-Za-z0-9_]*)(\\s*)(\\{)$",
          "captures": {
            "2": {
              "name": "keyword.control.declaration.bmsg"
            },
            "4": {
              "name": "entity.name.type.enum.bmsg"
            },
            "6": {
              "name": "punctuation.section.block.begin.bmsg"
            }
          }
        },
        {
          "name": "meta.declaration.message.bmsg",
          "match": "^(\\s*)(message)(\\s+)([A-Za-z_][A-Za-z0-9_]*)(\\s*)(\\{)$",
          "captures": {
            "2": {
              "name": "keyword.control.declaration.bmsg"
            },
            "4": {
              "name": "entity.name.type.message.bmsg"
            },
            "6": {
              "name": "punctuation.section.block.begin.bmsg"
            }
          }
        }
      ]
    },
    "field": {
      "patterns": [
        {
          "name": "meta.field.declaration.bmsg",
          "match": "^(\\s*)((?:map<[^>]+>|list<[^>]+>|[A-Za-z_][A-Za-z0-9_]*))(\\s+)([A-Za-z_][A-Za-z0-9_]*)(\\s*)(=)(\\s*)(\\d+)(?=\\s*(?://.*)?$)",
          "captures": {
            "2": {
              "name": "storage.type.field.bmsg"
            },
            "4": {
              "name": "variable.other.member.bmsg"
            },
            "6": {
              "name": "keyword.operator.assignment.bmsg"
            },
            "8": {
              "name": "constant.numeric.integer.bmsg"
            }
          }
        }
      ]
    },
    "enum-value": {
      "patterns": [
        {
          "name": "meta.enum.value.bmsg",
          "match": "^(\\s*)([A-Z][A-Z0-9_]*)(\\s*)(=)(\\s*)(-?\\d+)(?=\\s*(?://.*)?$)",
          "captures": {
            "2": {
              "name": "constant.other.enum-member.bmsg"
            },
            "4": {
              "name": "keyword.operator.assignment.bmsg"
            },
            "6": {
              "name": "constant.numeric.integer.bmsg"
            }
          }
        }
      ]
    },
    "builtin-types": {
      "patterns": [
        {
          "name": "storage.type.primitive.bmsg",
          "match": "\\b(?:bool|int32|int64|uint32|uint64|float32|float64|string|bytes)\\b"
        },
        {
          "name": "support.type.collection.bmsg",
          "match": "\\b(?:list|map)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.bmsg",
          "match": "="
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.integer.bmsg",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.section.block.begin.bmsg",
          "match": "\\{"
        },
        {
          "name": "punctuation.section.block.end.bmsg",
          "match": "\\}"
        },
        {
          "name": "punctuation.definition.generic.begin.bmsg",
          "match": "<"
        },
        {
          "name": "punctuation.definition.generic.end.bmsg",
          "match": ">"
        },
        {
          "name": "punctuation.separator.comma.bmsg",
          "match": ","
        }
      ]
    }
  }
}
