{
  "name": "bytemsg233-vscode",
  "displayName": "ByteMsg233 Syntax",
  "description": "Syntax highlighting and language support for ByteMsg .bmsg schema files.",
  "version": "0.1.0",
  "publisher": "neko233-com",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/neko233-com/bytemsg233.git"
  },
  "homepage": "https://github.com/neko233-com/bytemsg233",
  "bugs": {
    "url": "https://github.com/neko233-com/bytemsg233/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "bytemsg",
    "bmsg",
    "schema",
    "serialization"
  ],
  "galleryBanner": {
    "color": "#0f172a",
    "theme": "dark"
  },
  "contributes": {
    "languages": [
      {
        "id": "bmsg",
        "aliases": [
          "ByteMsg",
          "bmsg"
        ],
        "extensions": [
          ".bmsg"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "bmsg",
        "scopeName": "source.bmsg",
        "path": "./syntaxes/bmsg.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "bmsg",
        "path": "./snippets/bmsg.json"
      }
    ]
  },
  "scripts": {
    "package": "vsce package",
    "publish:vsce": "vsce publish"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.6.2"
  }
}
