{
  "ByteMsg Schema": {
    "prefix": "bmsg-schema",
    "body": [
      "schema: bymsg/v1",
      "package: ${1:com.example.app}",
      "",
      "enum ${2:Status} {",
      "    ${3:ACTIVE} = 0",
      "    ${4:INACTIVE} = 1",
      "}",
      "",
      "message ${5:Example} {",
      "    uint32 id = 1 // \"${6:ID}\" | \"${7:ID}\"",
      "    string name = 2 // \"${8:名称}\" | \"${9:Name}\"",
      "}"
    ],
    "description": "Create a basic ByteMsg schema"
  },
  "ByteMsg Message": {
    "prefix": "bmsg-message",
    "body": [
      "message ${1:MessageName} {",
      "    ${2:uint32} ${3:id} = ${4:1} // \"${5:字段说明}\" | \"${6:Field Description}\"",
      "}"
    ],
    "description": "Create a ByteMsg message block"
  },
  "ByteMsg Enum": {
    "prefix": "bmsg-enum",
    "body": [
      "enum ${1:EnumName} {",
      "    ${2:FIRST} = 0",
      "    ${3:SECOND} = 1",
      "}"
    ],
    "description": "Create a ByteMsg enum block"
  }
}
